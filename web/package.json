{
  "name": "coverage-compass-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "gen:rules": "node scripts/gen-rules.mjs",
    "vendor:ocr": "node scripts/vendor-ocr.mjs",
    "predev": "npm run gen:rules && npm run vendor:ocr",
    "dev": "vite",
    "prebuild": "npm run gen:rules && npm run vendor:ocr",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pretest": "npm run gen:rules",
    "test": "vitest run",
    "pretest:watch": "npm run gen:rules",
    "test:watch": "vitest",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\""
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-aria-components": "^1.4.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/spa": "^1.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "axe-core": "^4.10.2",
    "eslint": "^9.14.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "js-yaml": "^4.2.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
